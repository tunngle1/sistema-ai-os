# PostgreSQL (Neon / Vercel Postgres). Локально можно использовать Neon или Docker Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# AI (серверные переменные — не попадают на фронтенд)
QWEN_API_KEY="your-api-key-here"
QWEN_BASE_URL="https://your-workspace.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen3.7-plus"
